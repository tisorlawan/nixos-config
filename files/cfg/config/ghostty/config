keybind = all:alt+one=unbind
keybind = all:alt+two=unbind
keybind = all:alt+three=unbind
keybind = all:alt+four=unbind
keybind = all:alt+five=unbind
keybind = all:alt+six=unbind
keybind = all:alt+seven=unbind
keybind = all:alt+eight=unbind
keybind = all:alt+nine=unbind
keybind = all:alt+n=unbind
keybind = all:alt+p=unbind
keybind = all:alt+s=unbind
keybind = all:alt+shift+s=unbind
keybind = ctrl+enter=unbind

keybind = alt+o=new_split:right
keybind = alt+i=new_split:down
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up
keybind = alt+l=goto_split:right

keybind = alt+f=toggle_split_zoom

resize-overlay = never
faint-opacity = 1.0

keybind = ctrl+shift+o=toggle_quick_terminal
keybind = ctrl+shift+u=write_scrollback_file:copy

mouse-scroll-multiplier = precision:1

