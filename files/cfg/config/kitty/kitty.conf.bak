enabled_layouts splits,stack
allow_remote_control yes
listen_on unix:/tmp/kitty-agung-b-sorlawan.sock
shell /home/agung-b-sorlawan/.scripts/clean-terminal-shell
scrollback_lines 100000

# nixGL is only for kitty's renderer. Child processes should use the host
# graphics stack, including commands launched directly from kitty sessions.
env LD_LIBRARY_PATH=
env LIBGL_DRIVERS_PATH=
env GBM_BACKENDS_PATH=
env __EGL_VENDOR_LIBRARY_DIRS=
env __EGL_VENDOR_LIBRARY_FILENAMES=
env VK_ICD_FILENAMES=
env LIBVA_DRIVER_NAME=iHD
env LIBVA_DRIVERS_PATH=/usr/lib/x86_64-linux-gnu/dri

font_family      family='Berkeley Mono' postscript_name=BerkeleyMono-Regular
font_size        14
modify_font      cell_height        2px
modify_font      underline_position 2px
bold_font        auto
italic_font      auto
bold_italic_font auto
text_composition_strategy legacy
# - Symbols Nerd Font
# - JetBrainsMono Nerd Font
# - JetBrainsMonoNL Nerd Font
# - BlexMono Nerd Font
symbol_map U+E000-U+F8FF BlexMono Nerd Font
symbol_map U+F0000-U+FFFFD BlexMono Nerd Font
symbol_map U+100000-U+10FFFD BlexMono Nerd Font

# Transparency / opacity
background_opacity 0.94

# Cursor animation / trail
cursor_trail 1
cursor_trail_decay 0.0 0.3
cursor_trail_start_threshold 4

map ctrl+shift+enter launch --location=vsplit --cwd=current --bias=40
map ctrl+shift+backslash launch --location=hsplit --cwd=current
map alt+o launch --location=vsplit --cwd=current --bias=40
map alt+i launch --location=hsplit --cwd=current

# Link clicks: plain click does nothing, Ctrl+click opens the link.
mouse_map left click ungrabbed
mouse_map ctrl+left press grabbed discard_event
mouse_map ctrl+left release grabbed,ungrabbed mouse_handle_click link

map alt+h neighboring_window left
map alt+j neighboring_window down
map alt+k neighboring_window up
map alt+l neighboring_window right
map alt+f toggle_layout stack

# tab_bar_style hidden
tab_bar_min_tabs 4
map alt+b launch --type=background --allow-remote-control kitten @ load-config --no-response --override tab_bar_min_tabs=1
map alt+shift+b launch --type=background --allow-remote-control kitten @ load-config --no-response --override tab_bar_min_tabs=10

map ctrl+shift+p kitten command-palette
map ctrl+shift+t no_op
map alt+g launch --type=tab --cwd=current
map alt+r set_tab_title
# map alt+t select_tab

map alt+1 goto_tab 1
map alt+2 goto_tab 2
map alt+3 goto_tab 3
map alt+4 goto_tab 4
map alt+5 goto_tab 5
map alt+6 goto_tab 6
map alt+n next_tab
map alt+p previous_tab
map ctrl+shift+left move_tab_backward
map ctrl+shift+right move_tab_forward


# BEGIN_KITTY_THEME
# Nightfox
include current-theme.conf
# END_KITTY_THEME

cursor_shape block
# cursor none
