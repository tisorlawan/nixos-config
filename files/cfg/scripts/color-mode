#!/usr/bin/env bash

set -euo pipefail

mode="${COLOR:-}"

if [ -z "$mode" ] && [ -f "$HOME/.color" ]; then
    mode="$(< "$HOME/.color")"
fi

mode="$(printf '%s' "$mode" | tr '[:upper:]' '[:lower:]' | tr -s '[:space:]' ' ' | sed 's/^ //; s/ $//')"

case "$mode" in
    light|"monochrome light"|"light monochrome"|monochrome_light|light_monochrome|monochrome-light|light-monochrome|monochromelight|lightmonochrome|*light*)
        printf '%s\n' light
        ;;
    dark|"monochrome dark"|"dark monochrome"|monochrome_dark|dark_monochrome|monochrome-dark|dark-monochrome|monochromedark|darkmonochrome|*dark*)
        printf '%s\n' dark
        ;;
    *)
        printf '%s\n' dark
        ;;
esac
