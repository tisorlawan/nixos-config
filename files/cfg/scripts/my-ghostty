write_if_changed() {
  local destination="$1"
  local tmp

  tmp="$(mktemp "${destination}.XXXXXX")"
  cat >"$tmp"

  if [ -f "$destination" ] && cmp -s "$tmp" "$destination"; then
    rm -f "$tmp"
    return 0
  fi

  mv "$tmp" "$destination"
}

ensure_btop_theme() {
  local desired_line

  mkdir -p "$BTOP_DIR"
  desired_line="color_theme = \"$BTOP_THEME\""

  if [ -f "$BTOP_CONF" ] && grep -qxF "$desired_line" "$BTOP_CONF"; then
    return 0
  fi

  if [ -f "$BTOP_CONF" ]; then
    if grep -q '^color_theme\s*=' "$BTOP_CONF"; then
      sed -i "s|^color_theme\s*=.*$|$desired_line|" "$BTOP_CONF"
    else
      printf '\n%s\n' "$desired_line" >>"$BTOP_CONF"
    fi
  else
    printf '%s\n' "$desired_line" >"$BTOP_CONF"
  fi
}

mkdir -p "$GHOSTTY_DIR"
render_ghostty_config | write_if_changed "$GHOSTTY_CONF"

if [ "$COLOR_MODE" = "light" ]; then
  BTOP_THEME="adwaita"
else
  BTOP_THEME="kanagawa-wave"
fi

ensure_btop_theme

if [ "$WRITE_CONFIG_ONLY" -eq 1 ]; then
  exit 0
fi

ACTIVE_GHOSTTY_CWD="$(get_active_ghostty_cwd || true)"

if [ "$MY_GHOSTTY_DEBUG" = "1" ]; then
  printf 'my-ghostty cwd=%s\n' "${ACTIVE_GHOSTTY_CWD:-<unset>}" >&2
fi

GHOSTTY_RUN=(ghostty)
if command -v nixGLIntel >/dev/null 2>&1; then
  GHOSTTY_RUN=(nixGLIntel ghostty)
fi

if [ -n "$ACTIVE_GHOSTTY_CWD" ]; then
  exec "${GHOSTTY_RUN[@]}" --working-directory="$ACTIVE_GHOSTTY_CWD" "$@"
fi

exec "${GHOSTTY_RUN[@]}" "$@"
