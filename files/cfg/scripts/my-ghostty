#!/usr/bin/env bash

set -euo pipefail

WRITE_CONFIG_ONLY=0
if [ "${1:-}" = "--write-config-only" ]; then
  WRITE_CONFIG_ONLY=1
  shift
fi

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
COLOR_MODE="$($SCRIPT_DIR/color-mode)"

BTOP_DIR="$HOME/.config/btop"
BTOP_CONF="$BTOP_DIR/btop.conf"
GHOSTTY_DIR="$HOME/.config/ghostty"
GHOSTTY_CONF="$GHOSTTY_DIR/config"
MY_GHOSTTY_DEBUG="${MY_GHOSTTY_DEBUG:-0}"

get_active_ghostty_cwd() {
  local pid json class cwd shell_pid

  command -v hyprctl >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1
  [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] || return 1

  json="$(hyprctl activewindow -j 2>/dev/null)" || return 1

  class="$(printf '%s\n' "$json" | jq -r '(.class // "") | ascii_downcase')"
  case "$class" in
  *ghostty* | com.ghostty.tiso | ghost) ;;
  *) return 1 ;;
  esac

  pid="$(printf '%s\n' "$json" | jq -r '.pid // empty')"
  [ -n "$pid" ] && [ -d "/proc/$pid" ] || return 1

  shell_pid="$(ps --ppid "$pid" -o pid= 2>/dev/null | head -1 | tr -d ' ')"
  [ -n "$shell_pid" ] || return 1

  fish_pid="$(ps --ppid "$shell_pid" -o pid= 2>/dev/null | head -1 | tr -d ' ')"
  if [ -n "$fish_pid" ] && [ -d "/proc/$fish_pid/cwd" ]; then
    shell_pid="$fish_pid"
  fi

  cwd="$(readlink -f "/proc/$shell_pid/cwd" 2>/dev/null)" || return 1
  [ -n "$cwd" ] && [ -d "$cwd" ] || return 1

  [ "$MY_GHOSTTY_DEBUG" = "1" ] && printf 'my-ghostty pid=%s shell=%s cwd=%s\n' "$pid" "$shell_pid" "$cwd" >&2

  printf '%s\n' "$cwd"
}

render_ghostty_config() {
  cat <<EOF
# AUTOGENERATED CONFIG by ~/.script/my-ghostty

$(if [ "$COLOR_MODE" = "light" ]; then
    printf '%s\n' 'background-opacity = 1.0'
    printf '%s\n' 'background = ffffff'
    printf '%s\n' 'foreground = 111111'
    printf '%s\n' 'cursor-color = 111111'
    printf '%s\n' 'cursor-text = ffffff'
    printf '%s\n' 'selection-background = cfe8ff'
    printf '%s\n' 'selection-foreground = 111111'
    printf '%s\n' 'palette = 0=000000'
    printf '%s\n' 'palette = 1=cc0000'
    printf '%s\n' 'palette = 2=008700'
    printf '%s\n' 'palette = 3=b58900'
    printf '%s\n' 'palette = 4=0066cc'
    printf '%s\n' 'palette = 5=aa33aa'
    printf '%s\n' 'palette = 6=008b8b'
