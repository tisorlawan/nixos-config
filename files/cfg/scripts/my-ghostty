    printf '%s\n' 'palette = 0=1f2937'
    printf '%s\n' 'palette = 1=f87171'
    printf '%s\n' 'palette = 2=4ade80'
    printf '%s\n' 'palette = 3=facc15'
    printf '%s\n' 'palette = 4=60a5fa'
    printf '%s\n' 'palette = 5=c084fc'
    printf '%s\n' 'palette = 6=2dd4bf'
    printf '%s\n' 'palette = 7=f3f4f6'
    printf '%s\n' 'palette = 8=64748b'
    printf '%s\n' 'palette = 9=fca5a5'
    printf '%s\n' 'palette = 10=86efac'
    printf '%s\n' 'palette = 11=fde047'
    printf '%s\n' 'palette = 12=93c5fd'
    printf '%s\n' 'palette = 13=d8b4fe'
    printf '%s\n' 'palette = 14=5eead4'
    printf '%s\n' 'palette = 15=f9fafb'
  fi)

font-family = "Berkeley Mono"
# font-size = 17
# adjust-cell-height = 2

# font-size = 16
# adjust-cell-height = 5

