#!/usr/bin/env bash

set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/waybar-workspace-toggle"
STATE_FILE="$STATE_DIR/hidden-workspaces"
GLOBAL_STATE_FILE="$STATE_DIR/global-hidden"
MODE_FILE="$STATE_DIR/mode"

mkdir -p "$STATE_DIR"
touch "$STATE_FILE"

if [ ! -f "$MODE_FILE" ]; then
  printf 'global\n' >"$MODE_FILE"
fi

die() {
  printf 'waybar-workspace-toggle: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing command: $1"
}

ensure_runtime_dir() {
  if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
  fi
}

ensure_hypr_instance_signature() {
  local instance

  if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
    return 0
  fi

  instance="$(hyprctl instances -j 2>/dev/null | jq -r '.[0].instance // empty')"
  [ -n "$instance" ] || die "HYPRLAND_INSTANCE_SIGNATURE is not set"
  export HYPRLAND_INSTANCE_SIGNATURE="$instance"
}

hypr_socket() {
  ensure_runtime_dir
  ensure_hypr_instance_signature
  printf '%s\n' "$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
}

show_bar() {
  pkill -SIGUSR1 waybar >/dev/null 2>&1 || true
}

hide_bar() {
  pkill -SIGUSR2 waybar >/dev/null 2>&1 || true
}

current_workspace() {
  hyprctl activeworkspace -j | jq -r '.id // empty'
}

current_mode() {
  if [ -f "$MODE_FILE" ]; then
    tr -d '\n' <"$MODE_FILE"
  else
    printf 'global\n'
  fi
}

set_mode() {
  printf '%s\n' "$1" >"$MODE_FILE"
}

global_is_hidden() {
  [ -f "$GLOBAL_STATE_FILE" ]
}

set_global_hidden() {
  : >"$GLOBAL_STATE_FILE"
}

set_global_shown() {
  rm -f "$GLOBAL_STATE_FILE"
}

workspace_is_hidden() {
  local workspace="$1"
  grep -qxF "$workspace" "$STATE_FILE"
}

hide_workspace() {
  local workspace="$1"
  workspace_is_hidden "$workspace" && return 0
  printf '%s\n' "$workspace" >>"$STATE_FILE"
}

show_workspace() {
  local workspace="$1"
  local tmp

  tmp="$(mktemp "${STATE_FILE}.XXXXXX")"
  grep -vxF "$workspace" "$STATE_FILE" >"$tmp" || true
  mv "$tmp" "$STATE_FILE"
}

apply_workspace_state() {
  local workspace="${1:-}"
  local mode

  mode="$(current_mode)"

  if global_is_hidden; then
    hide_bar
    return 0
  fi

  if [ "$mode" = "global" ]; then
    show_bar
    return 0
  fi

  if [ -z "$workspace" ]; then
    workspace="$(current_workspace)"
  fi

  [ -n "$workspace" ] || return 0

  if workspace_is_hidden "$workspace"; then
    hide_bar
  else
    show_bar
  fi
}

toggle_current_workspace() {
  local workspace

  set_mode workspace

  workspace="$(current_workspace)"
  [ -n "$workspace" ] || return 1

  if workspace_is_hidden "$workspace"; then
    show_workspace "$workspace"
    show_bar
  else
    hide_workspace "$workspace"
    hide_bar
  fi
}

toggle_global() {
  set_mode global

  if global_is_hidden; then
    set_global_shown
    show_bar
  else
    set_global_hidden
    hide_bar
  fi
}

listen() {
  local socket line workspace

  apply_workspace_state

  socket="$(hypr_socket)"
  [ -S "$socket" ] || die "hyprland event socket not found"

  socat -U - UNIX-CONNECT:"$socket" | while IFS= read -r line; do
    case "$line" in
      workspacev2*|workspace*|focusedmonv2*)
        workspace="$(current_workspace)"
        apply_workspace_state "$workspace"
        ;;
    esac
  done
}

main() {
  local cmd="${1:-listen}"
  local mode="${2:-workspace}"

  require_cmd hyprctl
  require_cmd jq
  require_cmd socat
  ensure_runtime_dir
  ensure_hypr_instance_signature

  case "$cmd" in
    listen) listen ;;
    toggle)
      case "$mode" in
        global) toggle_global ;;
        workspace) toggle_current_workspace ;;
        *) die "unknown toggle mode: $mode" ;;
      esac
      ;;
    apply) apply_workspace_state ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
