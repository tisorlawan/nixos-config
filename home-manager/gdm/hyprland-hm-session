#!/usr/bin/env bash
set -euo pipefail

hm_session_vars=
profile_bin=
hyprland_bin=
if [[ -r "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]]; then
  hm_session_vars="$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
  profile_bin="$HOME/.nix-profile/bin"
elif [[ -r "$HOME/.local/state/nix/profiles/profile/etc/profile.d/hm-session-vars.sh" ]]; then
  hm_session_vars="$HOME/.local/state/nix/profiles/profile/etc/profile.d/hm-session-vars.sh"
  profile_bin="$HOME/.local/state/nix/profiles/profile/bin"
fi

if [[ -n "$hm_session_vars" ]]; then
  set +u
  # shellcheck disable=SC1090
  . "$hm_session_vars"
  set -u
fi

if [[ -n "$profile_bin" ]]; then
  export PATH="$profile_bin:$PATH"
  hyprland_bin="$profile_bin/Hyprland"
fi

export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland
export NIXOS_OZONE_WL=1

# Do not import Nix/nixGL graphics overrides into the user manager/DBus
# activation environment. They are only valid for the wrapped Nix process and
# break Ubuntu-built Vulkan/OpenGL apps by mixing Nix Mesa with Ubuntu ICDs.
unset LD_LIBRARY_PATH LIBGL_DRIVERS_PATH GBM_BACKENDS_PATH __EGL_VENDOR_LIBRARY_DIRS __EGL_VENDOR_LIBRARY_FILENAMES VK_ICD_FILENAMES

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user import-environment PATH XDG_DATA_DIRS XDG_CONFIG_DIRS XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE NIXOS_OZONE_WL || true
fi

if command -v dbus-update-activation-environment >/dev/null 2>&1; then
  dbus-update-activation-environment --systemd PATH XDG_DATA_DIRS XDG_CONFIG_DIRS XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE NIXOS_OZONE_WL || true
fi

nixgl_wrapper="$profile_bin/nixGLIntel"
if [[ -x "$nixgl_wrapper" ]]; then
  # Hyprland itself still needs nixGL on Ubuntu. Terminals start their shells
  # through ~/.scripts/clean-terminal-shell to avoid leaking this into dev work.
  exec "$nixgl_wrapper" "$profile_bin/start-hyprland" --no-nixgl --path "$hyprland_bin"
else
  exec "$profile_bin/start-hyprland" --no-nixgl --path "$hyprland_bin"
fi
